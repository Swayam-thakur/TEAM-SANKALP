rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == 'admin';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function bookingParticipant() {
      return signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.workerId == request.auth.uid
      );
    }

    function invitedWorker() {
      return signedIn() &&
        resource.data.requestedWorkerIds != null &&
        request.auth.uid in resource.data.requestedWorkerIds;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /workers/{workerId} {
      allow read: if signedIn();
      allow write: if isSelf(workerId) || isAdmin();
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn();
      allow update: if bookingParticipant() || invitedWorker() || isAdmin();
      allow delete: if false;
    }

    match /worker_locations/{workerId} {
      allow read: if signedIn();
      allow write: if isSelf(workerId) || isAdmin();
    }

    match /chat_rooms/{roomId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    match /payments/{paymentId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.workerId == request.auth.uid ||
         isAdmin());
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if false;
    }

    match /worker_documents/{documentId} {
      allow read, write: if signedIn() &&
        (resource.data.workerId == request.auth.uid || isAdmin());
    }

    match /saved_addresses/{addressId} {
      allow read, write: if signedIn() &&
        (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    match /earnings/{earningId} {
      allow read: if signedIn() &&
        (resource.data.workerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
